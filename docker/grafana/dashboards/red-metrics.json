  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Количество HTTP-запросов в секунду (Rate). Показатель пропускной способности HTTP API.",
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\"}[1m]))",
          "legendFormat": "HTTP rate",
          "refId": "A"
        }
      ],
      "title": "Rate — HTTP",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Количество gRPC-запросов в секунду (Rate). Актуально для Scrapper.",
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_requests_seconds_count{application=\"$application\"}[1m]))",
          "legendFormat": "gRPC rate",
          "refId": "A"
        }
      ],
      "title": "Rate — gRPC",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Количество HTTP-ошибок 5xx в секунду (Errors).",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",status=~\"5..\"}[1m]))",
          "legendFormat": "HTTP 5xx",
          "refId": "A"
        }
      ],
      "title": "Errors — HTTP 5xx",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "95-й перцентиль времени обработки HTTP-запросов (Duration / Latency).",
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[5m])) by (le))",
          "legendFormat": "HTTP p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[5m])) by (le))",
          "legendFormat": "HTTP p50",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[5m])) by (le))",
          "legendFormat": "HTTP p99",
          "refId": "C"
        }
      ],
      "title": "Duration — HTTP latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "95-й перцентиль времени обработки gRPC-запросов (Duration).",
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(grpc_server_requests_seconds_bucket{application=\"$application\"}[5m])) by (le))",
          "legendFormat": "gRPC p95",
          "refId": "A"
        }
      ],
      "title": "Duration — gRPC latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Используемая JVM-память по типу: heap (RAM приложения) и nonheap. Алерт срабатывает при heap > 400 MiB.",
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"$application\"}) by (area)",
          "legendFormat": "{{area}}",
          "refId": "A"
        }
      ],
      "title": "Memory — JVM used bytes",
      "type": "timeseries",
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [419430400], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "2m",
        "frequency": "1m",
        "handler": 1,
        "message": "Heap-память приложения $application превысила 400 MiB",
        "name": "High JVM heap usage",
        "noDataState": "no_data"
      }
    }
  ],
  "refresh": "10s",
