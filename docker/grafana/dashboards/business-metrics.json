    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Количество входящих сообщений пользователя в Telegram-бот в секунду.",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 10,
      "targets": [
        {
          "expr": "sum(rate(user_messages_total{application=\"bot\"}[1m]))",
          "legendFormat": "messages/s",
          "refId": "A"
        }
      ],
      "title": "Bot — пользовательские сообщения / с",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Входящие сообщения с разбивкой по типу: command (команда /...) или text.",
